    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "http-status-codes": "^2.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^22.13.10",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.3"
  }
